{
  "name": "khotan-data",
  "version": "0.1.1",
  "description": "Data primitives for TypeScript — ETL pipelines, transforms, and Drizzle Postgres integration.",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "khotan": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.cts",
        "default": "./dist/index.cjs"
      }
    },
    "./pipeline": {
      "import": {
        "types": "./dist/pipeline.d.ts",
        "default": "./dist/pipeline.js"
      },
      "require": {
        "types": "./dist/pipeline.d.cts",
        "default": "./dist/pipeline.cjs"
      }
    },
    "./transform": {
      "import": {
        "types": "./dist/transform.d.ts",
        "default": "./dist/transform.js"
      },
      "require": {
        "types": "./dist/transform.d.cts",
        "default": "./dist/transform.cjs"
      }
    },
    "./drizzle": {
      "import": {
        "types": "./dist/drizzle.d.ts",
        "default": "./dist/drizzle.js"
      },
      "require": {
        "types": "./dist/drizzle.d.cts",
        "default": "./dist/drizzle.cjs"
      }
    },
    "./factory": {
      "import": {
        "types": "./dist/factory.d.ts",
        "default": "./dist/factory.js"
      },
      "require": {
        "types": "./dist/factory.d.cts",
        "default": "./dist/factory.cjs"
      }
    },
    "./plug": {
      "import": {
        "types": "./dist/plug-client.d.ts",
        "default": "./dist/plug-client.js"
      },
      "require": {
        "types": "./dist/plug-client.d.cts",
        "default": "./dist/plug-client.cjs"
      }
    }
  },
  "files": [
    "dist",
    "dist/templates",
    "AGENTS.md",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "lint": "eslint . --max-warnings 0",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "typecheck": "tsc --noEmit",
    "check": "npm run typecheck && npm run lint && npm run format:check && npm run test",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build",
    "changeset": "changeset",
    "release": "npm run build && changeset publish"
  },
  "keywords": [
    "data",
    "etl",
    "pipeline",
    "drizzle",
    "drizzle-orm",
    "postgres",
    "nextjs",
    "typescript",
    "transform",
    "data-management"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": ""
  },
  "engines": {
    "node": ">=18"
  },
  "peerDependencies": {
    "drizzle-orm": ">=0.35.0",
    "workflow": ">=0.1.0",
    "zod": ">=3.22.0"
  },
  "peerDependenciesMeta": {
    "workflow": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.4",
    "@eslint/js": "^9.28.0",
    "@types/prompts": "^2.4.9",
    "@vitest/coverage-v8": "^4.1.7",
    "drizzle-orm": "^0.45.2",
    "eslint": "^9.28.0",
    "prettier": "^3.5.3",
    "tsup": "^8.5.1",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.34.0",
    "vitest": "^4.1.7",
    "zod": "^3.25.76"
  },
  "packageManager": "npm@11.12.1",
  "dependencies": {
    "commander": "^14.0.3",
    "prompts": "^2.4.2"
  }
}
